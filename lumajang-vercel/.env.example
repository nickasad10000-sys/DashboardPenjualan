# Supabase
# Dapatkan dari: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Catatan:
# - Gunakan SERVICE_ROLE_KEY (bukan anon key) untuk akses penuh dari API routes
# - Jangan pernah expose SERVICE_ROLE_KEY di frontend
# - Di Vercel: tambahkan sebagai Environment Variables di Settings → Environment Variables
